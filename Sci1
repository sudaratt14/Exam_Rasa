<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>แบบทดสอบวิทยาศาสตร์ - จุดเดือดและจุดหลอมเหลว ความหนาแน่น</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 900px;
            margin: 0 auto;
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.3);
            overflow: hidden;
        }

        .header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 30px;
            text-align: center;
        }

        .header h1 {
            font-size: 28px;
            margin-bottom: 10px;
        }

        .header p {
            font-size: 16px;
            opacity: 0.9;
        }

        .score-bar {
            display: flex;
            justify-content: space-between;
            background: #f8f9fa;
            padding: 20px 30px;
            border-bottom: 2px solid #ddd;
            align-items: center;
        }

        .score-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 5px;
        }

        .score-value {
            font-size: 32px;
            font-weight: bold;
            color: #667eea;
        }

        .score-label {
            font-size: 14px;
            color: #666;
        }

        .content {
            padding: 30px;
        }

        .question-block {
            display: none;
        }

        .question-block.active {
            display: block;
            animation: slideIn 0.3s ease-in;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateX(20px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        .question-header {
            background: #f8f9fa;
            padding: 15px 20px;
            border-left: 5px solid #667eea;
            margin-bottom: 20px;
            border-radius: 5px;
        }

        .question-number {
            font-size: 12px;
            color: #999;
            margin-bottom: 5px;
        }

        .question-text {
            font-size: 18px;
            color: #333;
            font-weight: 500;
            line-height: 1.6;
        }

        .options {
            display: grid;
            gap: 12px;
            margin: 25px 0;
        }

        .option {
            display: flex;
            align-items: center;
            padding: 15px 20px;
            border: 2px solid #ddd;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s ease;
            background: white;
        }

        .option:hover:not(.answered) {
            border-color: #667eea;
            background: #f0f3ff;
        }

        .option.answered {
            cursor: not-allowed;
        }

        .option.correct {
            border-color: #28a745;
            background: #d4edda;
        }

        .option.incorrect {
            border-color: #dc3545;
            background: #f8d7da;
        }

        .option-label {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            background: white;
            border: 2px solid #ddd;
            border-radius: 50%;
            font-weight: bold;
            margin-right: 15px;
            color: #667eea;
            flex-shrink: 0;
            font-size: 18px;
        }

        .option.correct .option-label {
            background: #28a745;
            border-color: #28a745;
            color: white;
        }

        .option.incorrect .option-label {
            background: #dc3545;
            border-color: #dc3545;
            color: white;
        }

        .option-text {
            flex: 1;
            font-size: 15px;
            line-height: 1.5;
        }

        .option-icon {
            font-size: 20px;
            margin-left: 10px;
        }

        .feedback {
            margin-top: 20px;
            padding: 15px 20px;
            border-radius: 8px;
            display: none;
        }

        .feedback.show {
            display: block;
        }

        .feedback.correct {
            background: #d4edda;
            border: 1px solid #28a745;
            color: #155724;
        }

        .feedback.incorrect {
            background: #f8d7da;
            border: 1px solid #dc3545;
            color: #721c24;
        }

        .feedback-header {
            font-weight: bold;
            margin-bottom: 8px;
            font-size: 16px;
        }

        .answer-key {
            margin-top: 10px;
            padding: 10px;
            background: rgba(255,255,255,0.5);
            border-radius: 5px;
            font-size: 14px;
        }

        .answer-key strong {
            color: #333;
        }

        .button-group {
            display: flex;
            gap: 15px;
            justify-content: center;
            margin-top: 30px;
        }

        button {
            padding: 12px 30px;
            font-size: 16px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-weight: 600;
        }

        .btn-next {
            background: #667eea;
            color: white;
        }

        .btn-next:hover {
            background: #5568d3;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }

        .btn-next:disabled {
            background: #ccc;
            cursor: not-allowed;
            transform: none;
        }

        .btn-prev {
            background: #ddd;
            color: #333;
        }

        .btn-prev:hover {
            background: #ccc;
        }

        .btn-reset {
            background: #dc3545;
            color: white;
        }

        .btn-reset:hover {
            background: #c82333;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(220, 53, 69, 0.4);
        }

        .progress-bar {
            height: 4px;
            background: #e9ecef;
            margin-bottom: 20px;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
            transition: width 0.3s ease;
        }

        .result-screen {
            display: none;
            text-align: center;
            padding: 60px 30px;
        }

        .result-screen.show {
            display: block;
        }

        .result-score {
            font-size: 72px;
            font-weight: bold;
            color: #667eea;
            margin: 20px 0;
        }

        .result-text {
            font-size: 24px;
            color: #333;
            margin-bottom: 30px;
        }

        .result-detail {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 8px;
            margin-bottom: 30px;
            font-size: 16px;
            color: #666;
        }

        .emoji {
            font-size: 100px;
            margin: 20px 0;
        }

        @media (max-width: 768px) {
            .header h1 {
                font-size: 22px;
            }

            .question-text {
                font-size: 16px;
            }

            .score-bar {
                flex-direction: column;
                gap: 15px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Header -->
        <div class="header">
            <h1>📝 แบบทดสอบวิทยาศาสตร์</h1>
            <p>เรื่อง: จุดเดือด จุดหลอมเหลว และความหนาแน่นของสาร</p>
        </div>

        <!-- Score Bar -->
        <div class="score-bar">
            <div class="score-item">
                <span class="score-label">คะแนนที่ได้</span>
                <span class="score-value" id="scoreValue">0</span>
            </div>
            <div class="score-item">
                <span class="score-label">ข้อที่ทำ</span>
                <span class="score-value" id="progressText">1/50</span>
            </div>
            <div class="score-item">
                <span class="score-label">ร้อยละ</span>
                <span class="score-value" id="percentageValue">0%</span>
            </div>
        </div>

        <!-- Progress Bar -->
        <div class="progress-bar">
            <div class="progress-fill" id="progressBar" style="width: 0%"></div>
        </div>

        <!-- Content -->
        <div class="content">
            <!-- Question Blocks -->
            <div id="questionContainer"></div>

            <!-- Result Screen -->
            <div class="result-screen" id="resultScreen">
                <div class="emoji" id="resultEmoji">😊</div>
                <div class="result-text" id="resultMessage">ยินดีด้วย!</div>
                <div class="result-score" id="resultScore">0/50</div>
                <div class="result-detail" id="resultDetail"></div>
                <button class="btn-reset" onclick="resetExam()">ทำแบบทดสอบใหม่</button>
            </div>

            <!-- Navigation Buttons -->
            <div class="button-group" id="buttonGroup">
                <button class="btn-prev" id="prevBtn" onclick="previousQuestion()" style="display:none;">← ย้อนกลับ</button>
                <button class="btn-next" id="nextBtn" onclick="nextQuestion()" disabled>ถัดไป →</button>
                <button class="btn-reset" onclick="resetExam()">เริ่มใหม่</button>
            </div>
        </div>
    </div>

    <script>
        // ข้อมูลโจทย์ทั้ง 50 ข้อ
        const questions = [
            {num: 1, question: "ข้อใดต่อไปนี้กล่าวถึงความหมายของ 'สารบริสุทธิ์' ได้ถูกต้องที่สุด", choices: ["สารเนื้อเดียวที่มีส่วนผสมของสารตั้งแต่ 2 ชนิดขึ้นไป", "สารเนื้อผสมที่มีองค์ประกอบคงที่และแยกออกจากกันได้ง่าย", "สารเนื้อเดียวที่มีองค์ประกอบเพียงชนิดเดียว และมีสมบัติคงที่", "สารที่ไม่มีสิ่งเจือปนเลยและไม่สามารถเปลี่ยนสถานะได้"], answer: 2},
            {num: 2, question: "กราฟการให้ความร้อนแก่ของเหลวชนิดหนึ่ง พบว่า 'เมื่อของเหลวเริ่มเดือด อุณหภูมิจะคงที่ตลอดการเดือด ณ ความดันบรรยากาศหนึ่ง ๆ' ของเหลวนี้จัดเป็นสารประเภทใด", choices: ["สารบริสุทธิ์", "สารละลาย", "สารผสม", "สารเนื้อผสม"], answer: 0},
            {num: 3, question: "เมื่อนำน้ำเกลือซึ่งเป็นสารผสมไปต้มจนเดือด อุณหภูมิของน้ำเกลือขณะเดือดจะมีลักษณะอย่างไร", choices: ["คงที่เท่ากับจุดเดือดของน้ำบริสุทธิ์", "คงที่แต่สูงกว่าจุดเดือดของน้ำบริสุทธิ์", "ไม่คงที่และจะค่อย ๆ เพิ่มขึ้นเรื่อย ๆ", "ไม่คงที่และจะค่อย ๆ ลดลงเรื่อย ๆ"], answer: 2},
            {num: 4, question: "เหตุใดสารผสมที่เป็นสารละลายจึงมีจุดเดือดไม่คงที่ตลอดการเดือด", choices: ["เพราะสารผสมเกิดปฏิกิริยาเคมีสร้างสารใหม่ตลอดเวลา", "เพราะตัวทำละลายระเหยออกไปเรื่อย ๆ ทำให้ความเข้มข้นของสารละลายเปลี่ยนไป", "เพราะสารผสมมีความหนาแน่นเพิ่มขึ้นอย่างรวดเร็ว", "เพราะความดันบรรยากาศเหนือของเหลวมีการเปลี่ยนแปลง"], answer: 1},
            {num: 5, question: "ถ้าสาร X เริ่มหลอมเหลวที่อุณหภูมิ 115℃ และหลอมเหลวหมดที่อุณหภูมิ115.2℃ สาร X ควรจัดเป็นสารประเภทใดเพราะเหตุใด", choices: ["สารบริสุทธิ์เพราะมีช่วงการหลอมเหลวกว้าง", "สารบริสุทธิ์เพราะมีช่วงการหลอมเหลวแคบ", "สารผสม เพราะมีช่วงการหลอมเหลวแคบ", "สารผสม เพราะมีช่วงการหลอมเหลวกว้าง"], answer: 1},
            {num: 6, question: "สาร Y เริ่มหลอมเหลวที่อุณหภูมิ 65℃ และหลอมเหลวหมดที่อุณหภูมิ 73℃ จากข้อมูลนี้ข้อใดสรุปได้ถูกต้อง", choices: ["สาร Y เป็นสารบริสุทธิ์ที่มีสิ่งเจือปนน้อย", "สาร Y เป็นสารผสม เนื่องจากช่วงการหลอมเหลวห่างกันถึง 8℃", "สาร Y เป็นสารบริสุทธิ์เนื่องจากอุณหภูมิเริ่มต้นหลอมเหลวต่ำ", "สาร Y เป็นสารเนื้อผสมที่แยกชั้นชัดเจน"], answer: 1},
            {num: 7, question: "การเปรียบเทียบช่วงอุณหภูมิการหลอมเหลวระหว่างสารบริสุทธิ์และสารผสม ข้อใดถูกต้อง", choices: ["สารบริสุทธิ์มีช่วงการหลอมเหลวกว้างกว่าสารผสม", "สารผสมมีช่วงการหลอมเหลวแคบกว่าสารบริสุทธิ์", "สารบริสุทธิ์มีช่วงการหลอมเหลวแคบ ส่วนสารผสมมีช่วงการหลอมเหลวกว้าง", "ทั้งสารบริสุทธิ์และสารผสมมีช่วงการหลอมเหลวเท่ากัน"], answer: 2},
            {num: 8, question: "เครื่องมือวิทยาศาสตร์ชนิดใดที่จำเป็นที่สุดในการทดสอบเพื่อศึกษาจุดเดือดของสาร", choices: ["บีกเกอร์และแท่งแก้วคนสาร", "เทอร์มอมิเตอร์และชุดตะเกียงแอลกอฮอล์", "กระบอกตวงและเครื่องชั่งสาร", "หลอดทดลองและที่จับหลอดทดลอง"], answer: 1},
            {num: 9, question: "หากต้องการทดสอบว่าของเหลวใสไม่มีสีในขวดหนึ่งเป็น 'น้ำกลั่นบริสุทธิ์' หรือ 'น้ำเกลือ' วิธีการใดปลอดภัยและได้ผลแม่นยำที่สุด", choices: ["นำไปชิมรสชาติ", "นำไปดมกลิ่น", "นำไปตวงหาปริมาตร", "นำไปต้มเพื่อสังเกตความคงที่ของจุดเดือด"], answer: 3},
            {num: 10, question: "สารในข้อใดต่อไปนี้จัดเป็นสารบริสุทธิ์ทั้งหมด", choices: ["น้ำเกลือ น้ำเชื่อม อากาศ", "แก๊สออกซิเจน น้ำกลั่น ทองคำแท้", "ทองเหลือง น้ำนม น้ำนม", "น้ำคลอง น้ำโซดา น้ำปลา"], answer: 1},
            {num: 11, question: "สารในข้อใดต่อไปนี้จัดเป็นสารผสมทั้งหมด", choices: ["แก๊สไนโตรเจน ผงถ่าน เพชร", "น้ำตาลทราย เกลือแกง ผงชูรส", "น้ำหมึก อากาศ นาก", "ทองแดง สังกะสี อะลูมิเนียม"], answer: 1},
            {num: 12, question: "ข้อใดอธิบายจุดเดือดของสารได้ถูกต้อง", choices: ["อุณหภูมิที่ของเหลวเปลี่ยนสถานะเป็นแก๊สทั่วทั้งหมดของเหลว", "อุณหภูมิที่ของแข็งเปลี่ยนสถานะเป็นของเหลว", "อุณหภูมิที่ของเหลวเปลี่ยนสถานะเป็นของแข็ง", "อุณหภูมิที่แก๊สเปลี่ยนสถานะเป็นของเหลว"], answer: 0},
            {num: 13, question: "ณ ความดันบรรยากาศปกติ (1 atm) จุดเดือดของน้ำบริสุทธิ์มีค่าเท่าใด", choices: ["0℃", "50℃", "100℃", "120℃"], answer: 2},
            {num: 14, question: "เมื่อนำสารบริสุทธิ์ (A) และสารบริสุทธิ์ (B) ซึ่งเป็นสารคนละชนิดกันมาหาจุดเดือด ณ ความดันเดียวกัน ข้อใดมีโอกาสเกิดขึ้นได้มากที่สุด", choices: ["สาร (A) และ (B) จะต้องมีจุดเดือดเท่ากันเสมอ", "สาร (A) และ (B) จะมีจุดเดือดคงที่แต่ค่าจุดเดือดอาจไม่เท่ากัน", "สาร (A) จะมีจุดเดือดคงที่ ส่วนสาร (B) จะมีจุดเดือดไม่คงที่", "ทั้งสองสารจะมีจุดเดือดไม่คงที่แต่อุณหภูมิจะเท่ากัน"], answer: 1},
            {num: 15, question: "ในการทดลองต้มของเหลวเนื้อเดียวชนิดหนึ่งปรากฏว่าอุณหภูมิขณะเดือดเพิ่มขึ้นเรื่อย ๆ จาก 82℃ ไปจนถึง 95℃ ข้อใดสรุปได้ถูกต้องที่สุด", choices: ["ของเหลวนี้คือสารบริสุทธิ์ที่กำลังขยายตัว", "ของเหลวนี้คือสารผสม", "ของเหลวนี้เกิดการปนเปื้อนขณะเดือดเท่านั้น", "เทอร์มอมิเตอร์ที่ใช้ในการทดลองชำรุด"], answer: 1},
