            {num: 48, question: "ข้อใดอธิบายพฤติกรรมของ 'น้ำแข็ง' ที่ลอยน้ำได้ถูกต้องตามหลักความหนาแน่น", choices: ["น้ำแข็งมีมวลมากกว่าน้ำในปริมาตรเท่ากัน", "น้ำแข็งขยายตัวทำให้ปริมาตรเพิ่มขึ้น ความหนาแน่นจึงน้อยกว่าน้ำบริสุทธิ์", "น้ำแข็งเป็นสารผสมที่มีแก๊สปนอยู่มาก", "น้ำแข็งทำปฏิกิริยากับออกซิเจนในอากาศจึงลอยได้"], answer: 1},
            {num: 49, question: "ถ้าสาร (P) มีความหนาแน่น 0.5 g/cm³ สาร (Q) มีความหนาแน่น 2.0 g/cm³ ถ้านำสารทั้งสองที่มีปริมาตร 10 ลูกบาศก์เซนติเมตรเท่ากันมาคูณหามวล ข้อใดถูกต้อง", choices: ["สาร (P) มีมวลมากกว่าสาร (Q)", "สาร (Q) มีมวลมากกว่าสาร (P)", "ทั้งสองสารมีมวลเท่ากัน", "ไม่สามารถเปรียบเทียบมวลกันได้"], answer: 1},
            {num: 50, question: "ข้อใดสรุปเกี่ยวกับสมบัติของสารบริสุทธิ์และสารผสมได้ถูกต้องที่สุด", choices: ["สารบริสุทธิ์มีจุดเดือดคงที่ จุดหลอมเหลวแคบ ความหนาแน่นคงที่ณ สภาวะหนึ่ง ๆ", "สารผสมมีจุดเดือดคงที่แต่จุดหลอมเหลวกว้าง ความหนาแน่นไม่คงที่", "สารบริสุทธิ์มีจุดเดือดไม่คงที่ความหนาแน่นไม่คงที่แต่จุดหลอมเหลวแคบ", "สารผสมมีสมบัติทุกอย่างคงที่เหมือนสารบริสุทธิ์ทุกประการ"], answer: 0}
        ];

        let currentQuestion = 0;
        let score = 0;
        let answered = []; // เก็บคำตอบที่ตอบไปแล้ว

        function initExam() {
            renderQuestion();
            updateScore();
        }

        function renderQuestion() {
            const container = document.getElementById('questionContainer');
            container.innerHTML = '';

            questions.forEach((q, index) => {
                const block = document.createElement('div');
                block.className = `question-block ${index === currentQuestion ? 'active' : ''}`;
                block.id = `q${index}`;

                let optionsHTML = '';
                const labels = ['ก', 'ข', 'ค', 'ง'];
                q.choices.forEach((choice, i) => {
                    const isAnswered = answered[index] !== undefined;
                    const isCorrect = answered[index] === q.answer;
                    const selected = answered[index] === i;
                    let optionClass = '';
                    let iconHTML = '';

                    if (isAnswered && selected) {
                        if (isCorrect) {
                            optionClass = 'correct';
                            iconHTML = ' ✓';
                        } else {
                            optionClass = 'incorrect';
                            iconHTML = ' ✗';
                        }
                    }

                    optionsHTML += `
                        <div class="option ${optionClass} ${isAnswered ? 'answered' : ''}"
                             onclick="${!isAnswered ? `selectAnswer(${index}, ${i})` : ''}">
                            <span class="option-label">${labels[i]}</span>
                            <span class="option-text">${choice}</span>
                            <span class="option-icon">${iconHTML}</span>
                        </div>
                    `;
                });

                let feedbackHTML = '';
                if (answered[index] !== undefined) {
                    const isCorrect = answered[index] === q.answer;
                    feedbackHTML = `
                        <div class="feedback show ${isCorrect ? 'correct' : 'incorrect'}">
                            <div class="feedback-header">
                                ${isCorrect ? '✓ ตอบถูกแล้ว!' : '✗ ตอบผิด'}
                            </div>
                            <div class="answer-key">
                                <strong>คำตอบที่ถูก:</strong> ${labels[q.answer]}) ${q.choices[q.answer]}
                            </div>
                        </div>
                    `;
                }

                block.innerHTML = `
                    <div class="question-header">
                        <div class="question-number">ข้อที่ ${q.num} / 50</div>
                        <div class="question-text">${q.question}</div>
                    </div>
                    <div class="options">${optionsHTML}</div>
                    ${feedbackHTML}
                `;

                container.appendChild(block);
            });
        }

        function selectAnswer(questionIndex, choiceIndex) {
            answered[questionIndex] = choiceIndex;
            if (choiceIndex === questions[questionIndex].answer) {
                score++;
            }
            updateScore();
            renderQuestion();
            updateButtons();
        }

        function updateScore() {
            const percentage = Math.round((score / questions.length) * 100);
            document.getElementById('scoreValue').textContent = score;
            document.getElementById('progressText').textContent = `${Object.keys(answered).length}/50`;
            document.getElementById('percentageValue').textContent = `${percentage}%`;
            document.getElementById('progressBar').style.width = `${(Object.keys(answered).length / 50) * 100}%`;
        }

        function nextQuestion() {
            if (currentQuestion < questions.length - 1) {
                currentQuestion++;
                updateView();
            } else {
                showResults();
            }
        }

        function previousQuestion() {
            if (currentQuestion > 0) {
                currentQuestion--;
                updateView();
            }
        }

        function updateView() {
            document.querySelectorAll('.question-block').forEach(el => el.classList.remove('active'));
            document.getElementById(`q${currentQuestion}`).classList.add('active');
            updateButtons();
            window.scrollTo({top: 0, behavior: 'smooth'});
        }

        function updateButtons() {
            const prevBtn = document.getElementById('prevBtn');
            const nextBtn = document.getElementById('nextBtn');

            if (currentQuestion === 0) {
                prevBtn.style.display = 'none';
            } else {
                prevBtn.style.display = 'block';
            }

            if (answered[currentQuestion] !== undefined) {
                nextBtn.disabled = false;
                if (currentQuestion === questions.length - 1) {
                    nextBtn.textContent = 'ดูผลสอบ →';
                }
            } else {
                nextBtn.disabled = true;
            }
        }

        function showResults() {
            document.getElementById('questionContainer').style.display = 'none';
            document.getElementById('buttonGroup').style.display = 'none';

            const percentage = Math.round((score / questions.length) * 100);
            let resultMessage = '';
            let emoji = '';

            if (percentage === 100) {
                resultMessage = 'ยอดเยี่ยม! ทำได้ลูกเต่า 💯';
                emoji = '🏆';
            } else if (percentage >= 80) {
                resultMessage = 'ดีมาก! ตัวจริง 😊';
                emoji = '⭐';
            } else if (percentage >= 60) {
                resultMessage = 'ดี! ทำอีกแปบนะ 👍';
                emoji = '😌';
            } else if (percentage >= 40) {
                resultMessage = 'พยายามเข้า! ต่อไปจะดีขึ้น 💪';
                emoji = '😅';
            } else {
                resultMessage = 'ต้องทำความเข้าใจเพิ่มเติม 📚';
                emoji = '😌';
            }

            document.getElementById('resultEmoji').textContent = emoji;
            document.getElementById('resultMessage').textContent = resultMessage;
            document.getElementById('resultScore').textContent = `${score}/50`;
            document.getElementById('resultDetail').textContent = `คะแนน: ${score} คะแนน | ร้อยละ: ${percentage}%`;
            document.getElementById('resultScreen').classList.add('show');
        }

        function resetExam() {
            currentQuestion = 0;
            score = 0;
            answered = [];
            document.getElementById('questionContainer').style.display = 'block';
            document.getElementById('buttonGroup').style.display = 'flex';
            document.getElementById('resultScreen').classList.remove('show');
            updateScore();
            renderQuestion();
            updateButtons();
            window.scrollTo({top: 0, behavior: 'smooth'});
        }

        // Initialize
        window.addEventListener('DOMContentLoaded', initExam);
    </script>
</body>
</html>
